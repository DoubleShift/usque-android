<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e">

    <!-- Top bar: title + settings logo button -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:text="Usque VPN"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#ffffff" />

        <ImageButton
            android:id="@+id/settings_button"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_alignParentEnd="true"
            android:src="@drawable/ic_vpn"
            android:scaleType="centerCrop"
            android:background="@drawable/button_circle_background"
            android:contentDescription="Settings" />

    </RelativeLayout>

    <!-- Center content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">

        <!-- Connect / Connected toggle button (also shows status) -->
        <Button
            android:id="@+id/connect_button"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:text="Connect"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:background="@drawable/button_background"
            android:layout_marginBottom="24dp" />

        <!-- IP / SNI / Endpoint info (compact) -->
        <TextView
            android:id="@+id/ip_info_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Not registered"
            android:textSize="12sp"
            android:textColor="#aaaaaa"
            android:gravity="center"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/sni_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SNI: www.visa.cn"
            android:textSize="11sp"
            android:textColor="#666666" />

        <TextView
            android:id="@+id/endpoint_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Endpoint: 162.159.198.1"
            android:textSize="11sp"
            android:textColor="#666666"
            android:layout_marginBottom="16dp" />

        <!-- Per-App Proxy Card (compact) -->
        <LinearLayout
            android:id="@+id/per_app_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/card_background"
            android:padding="14dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Per-App Proxy"
                    android:textSize="10sp"
                    android:textColor="#888888"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/per_app_status_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Off — all apps use VPN"
                    android:textSize="13sp"
                    android:textColor="#ffffff"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage ›"
                android:textSize="12sp"
                android:textColor="#4e8aff" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
