<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#ffffff">

    <!-- Top bar: title + settings logo button -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:text="RE.usque"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1a1a2e" />

        <ImageButton
            android:id="@+id/settings_button"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_alignParentEnd="true"
            android:src="@drawable/ic_vpn"
            android:scaleType="centerCrop"
            android:background="@drawable/button_circle_background"
            android:contentDescription="Settings" />

    </RelativeLayout>

    <!-- Center content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="28dp"
        android:paddingEnd="28dp">

        <!-- Connect / Connected toggle button (circular) -->
        <Button
            android:id="@+id/connect_button"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:text="Connect"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:background="@drawable/button_background"
            android:layout_marginBottom="28dp" />

        <!-- IP info block (left-aligned, black, larger) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/ipv4_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="IPv4: Not registered"
                android:textSize="15sp"
                android:textColor="#000000"
                android:gravity="start" />

            <TextView
                android:id="@+id/ipv6_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="IPv6: Not registered"
                android:textSize="15sp"
                android:textColor="#000000"
                android:gravity="start"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/sni_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SNI: www.visa.cn"
                android:textSize="13sp"
                android:textColor="#666666"
                android:gravity="start"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/endpoint_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Endpoint: 162.159.198.1"
                android:textSize="13sp"
                android:textColor="#666666"
                android:gravity="start"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Per-App Proxy Card (pinned to bottom) -->
    <LinearLayout
        android:id="@+id/per_app_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/card_background"
        android:padding="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Per-App Proxy"
                android:textSize="10sp"
                android:textColor="#999999"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/per_app_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Off — all apps use VPN"
                android:textSize="14sp"
                android:textColor="#1a1a2e"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#6c5ce7" />

    </LinearLayout>

</LinearLayout>
