<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#1a1a2e">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- Logo/Icon -->
        <ImageView
            android:id="@+id/logo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_vpn"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp" />

        <!-- App Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Usque VPN"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cloudflare WARP / MASQUE"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_marginBottom="24dp" />

        <!-- Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="24dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status"
                android:textSize="12sp"
                android:textColor="#888888"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Disconnected"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#ff6b6b"
                android:layout_marginTop="4dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#333333"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your IP Address"
                android:textSize="12sp"
                android:textColor="#888888"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/ip_info_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Not registered"
                android:textSize="14sp"
                android:textColor="#ffffff"
                android:layout_marginTop="4dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#333333"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <!-- Connection Settings Preview -->
            <TextView
                android:id="@+id/sni_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SNI: www.visa.cn"
                android:textSize="12sp"
                android:textColor="#aaaaaa" />

            <TextView
                android:id="@+id/endpoint_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Endpoint: 162.159.198.1"
                android:textSize="12sp"
                android:textColor="#aaaaaa"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- Per-App Proxy Card -->
        <LinearLayout
            android:id="@+id/per_app_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Per-App Proxy"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/per_app_status_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Off — all apps use VPN"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage ›"
                android:textSize="13sp"
                android:textColor="#4e8aff" />

        </LinearLayout>

        <!-- Settings + Connect Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/settings_button"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="⚙ Settings"
                android:textSize="14sp"
                android:textColor="#ffffff"
                android:background="@drawable/button_secondary_background"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/connect_button"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Connect"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:background="@drawable/button_background"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <!-- Disconnect Button (full width) -->
        <Button
            android:id="@+id/disconnect_button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Disconnect"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:background="@drawable/button_danger_background"
            android:layout_marginBottom="16dp" />

        <!-- Footer -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Powered by usque"
            android:textSize="12sp"
            android:textColor="#555555"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>

</ScrollView>
